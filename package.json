{
  "name": "edge-of-the-empire",
  "version": "1.0.0",
  "description": "Star Wars TTRPG Electronic Character Sheet — The Edge of the Empire",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"nodemon server/index.js\" \"npm run css:watch\"",
    "css:build": "tailwindcss --config tailwind.config.js -i ./css/input.css -o ./public/css/output.css",
    "css:watch": "tailwindcss --config tailwind.config.js -i ./css/input.css -o ./public/css/output.css --watch"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^9.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.18.3",
    "node-html-to-image": "^5.0.0",
    "pg": "^8.20.0",
    "puppeteer": "^22.15.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "tailwindcss": "^3.4.1"
  }
}
